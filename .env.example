# Magic Sky Ecommerce - Environment Variables
# Copy to .env and fill values

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/magic_sky?schema=public"

# Redis (optional, for cache/queues)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# App
NODE_ENV="development"
PORT=4000
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5173/admin"

# Wompi (Colombia payment gateway)
WOMPI_PUBLIC_KEY=""
WOMPI_PRIVATE_KEY=""
WOMPI_INTEGRITY_SECRET=""
WOMPI_ENV="sandbox"
WOMPI_REDIRECT_URL="http://localhost:5173/checkout/complete"

# File Storage (local for dev)
STORAGE_TYPE="local"
STORAGE_LOCAL_PATH="./uploads"

# CORS (comma-separated origins)
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
